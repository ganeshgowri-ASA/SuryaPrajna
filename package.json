{
  "name": "suryaprajna",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "desktop:dev": "pnpm --filter @suryaprajna/desktop dev",
    "desktop:build": "pnpm --filter @suryaprajna/desktop build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "turbo": "^2.3.0"
  }
}
