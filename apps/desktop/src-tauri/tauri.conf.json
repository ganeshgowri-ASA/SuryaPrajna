{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "SuryaPrajna",
  "version": "0.1.0",
  "identifier": "com.suryaprajna.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --filter @suryaprajna/web dev",
    "beforeBuildCommand": "pnpm --filter @suryaprajna/web build"
  },
  "app": {
    "title": "SuryaPrajna — Solar PV Workspace",
    "windows": [
      {
        "label": "main",
        "title": "SuryaPrajna",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "SuryaPrajna"
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: https:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["msi", "dmg", "appimage"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": [
          "$HOME/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$DESKTOP/**"
        ]
      }
    },
    "shell": {
      "scope": [
        {
          "name": "python",
          "cmd": "python3",
          "args": true
        }
      ]
    }
  }
}
