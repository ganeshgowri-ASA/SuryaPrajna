# =============================================================================
# SuryaPrajna — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values as needed.
# Never commit .env to version control.

# --- LLM API Keys ---
ANTHROPIC_API_KEY=                 # Required for Claude-based agents and embeddings
OPENAI_API_KEY=                    # Required for OpenAI embeddings (text-embedding-3-large)

# --- Real-Time Search ---
PERPLEXITY_API_KEY=                # Perplexity AI — real-time literature search and fact verification
                                   # Get at: https://www.perplexity.ai/settings/api

# --- Academic APIs ---
SEMANTIC_SCHOLAR_API_KEY=          # Semantic Scholar — paper search and citation analysis
                                   # Get at: https://www.semanticscholar.org/product/api
SCOPUS_API_KEY=                    # Elsevier Scopus — citation metrics, journal rankings
                                   # Get at: https://dev.elsevier.com/
CROSSREF_API_KEY=                  # CrossRef — DOI resolution and publisher metadata
                                   # Get at: https://www.crossref.org/documentation/metadata-plus/

# --- AI Writing Assistance ---
JENNI_AI_KEY=                      # Jenni.ai — AI writing and literature review augmentation
                                   # Get at: https://jenni.ai/

# --- Vector Database (Knowledge Retrieval) ---
PINECONE_API_KEY=                  # Pinecone — vector DB for semantic knowledge retrieval
                                   # Get at: https://app.pinecone.io/
PINECONE_INDEX_NAME=surya-prajna-pv  # Default index name

# --- Reference Management ---
ZOTERO_API_KEY=                    # Zotero Web API — reference and citation management
                                   # Get at: https://www.zotero.org/settings/keys
ZOTERO_LIBRARY_ID=                 # Your Zotero user or group library ID
ZOTERO_LIBRARY_TYPE=user           # 'user' for personal library, 'group' for group library

# --- Weather Data ---
OPENWEATHER_API_KEY=               # OpenWeatherMap — weather data (alternative source)

# --- Vercel Deployment (CI/CD) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Optional: Hugging Face (ML Models) ---
HF_TOKEN=
